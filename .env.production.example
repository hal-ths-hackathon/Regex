# =============================================================================
# .env.production.example — 本番環境用 環境変数テンプレート
# =============================================================================
# このファイルをコピーして .env.production を作成し、実際の値を設定してください。
#   cp .env.production.example .env.production
#
# .env.production は .gitignore で除外されるため、リポジトリにコミットされません。
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=regex_prod
POSTGRES_PASSWORD=<STRONG_PASSWORD_HERE>
POSTGRES_DB=regex_prod
DATABASE_URL=postgresql+psycopg2://regex_prod:<STRONG_PASSWORD_HERE>@db:5432/regex_prod

# --- Cloudflare Tunnel ---
# Cloudflare Zero Trust ダッシュボード > Access > Tunnels で作成し、
# トンネルのトークンをここに貼り付けてください。
CLOUDFLARE_TUNNEL_TOKEN=<YOUR_TUNNEL_TOKEN>

# --- CORS (バックエンド) ---
# Cloudflare Tunnel 経由で公開するドメインを指定してください。
# 複数指定する場合はカンマ区切り: https://example.com,https://www.example.com
CORS_ORIGINS=https://<YOUR_DOMAIN>
